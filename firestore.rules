rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if true; // Allow for demo/simulation
    }

    // Needs
    match /needs/{needId} {
      allow read: if true;
      allow write: if true; // Allow for donor pledging and simulated admin listing
    }

    // Pledges
    match /pledges/{pledgeId} {
      allow read: if true;
      allow write: if true; // Allow anyone to simulate a pledge
    }

    // Admins collection (read-only for the user themselves)
    match /admins/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if false; // Only manageable via Firebase Console or Admin SDK
    }
  }
}
